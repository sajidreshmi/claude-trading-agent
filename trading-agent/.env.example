# ─── Trading Agent Configuration ─────────────────────────────────
# Copy this to .env and fill in your values

# LLM
ANTHROPIC_API_KEY=your-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# Agent Limits
COORDINATOR_MAX_ITERATIONS=15
SUBAGENT_MAX_ITERATIONS=10

# Risk Hooks (deterministic — code enforced)
RISK_THRESHOLD=0.7
MIN_CONFIDENCE=0.5
MAX_POSITION_USD=10000.0
MAX_PORTFOLIO_CONCENTRATION=0.20
MAX_SECTOR_EXPOSURE=0.40

# Rate Limiting
TOOL_RATE_LIMIT_PER_MINUTE=30
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SEC=60.0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
